# Required: Authentication token for the web UI
BEARER_TOKEN=your_secret_token_here

# Optional: Separate token for permission hooks (defaults to BEARER_TOKEN)
# HOOK_TOKEN=your_hook_token_here

# Optional: Server port (default: 5678)
# PORT=5678

# Optional: Directory containing your projects (default: ~/Documents/Project)
# PROJECTS_DIR=~/projects

# Optional: Cloudflare Access domain for CSP headers
# CF_ACCESS_DOMAIN=your-app.cloudflareaccess.com

# Optional: Telegram Bot integration
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# Optional: Allow non-CliHub sessions to bypass permission hook (default: deny)
# CLIHUB_HOOK_ALLOW_EXTERNAL=0
